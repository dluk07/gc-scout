# GameChanger private-API token (JWT), captured from your logged-in session.
# See README "Phase 0" for how to grab it from the browser console.
# It expires periodically - re-capture when the tool reports a 401.
GC_TOKEN=

# Your team's UUID (also captured in Phase 0). Optional once known.
MY_TEAM_ID=

# Sport for opponent search: baseball | softball
GC_SPORT=softball
